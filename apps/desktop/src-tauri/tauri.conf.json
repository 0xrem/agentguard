{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentGuard",
  "version": "0.1.0",
  "identifier": "com.agentguard.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && cargo build --release -p agentguard-daemon -p agentguard-proxy",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentGuard",
        "width": 1480,
        "height": 980,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "bundle-resources/runtime/agentguard-daemon": "runtime/agentguard-daemon",
      "bundle-resources/runtime/agentguard-proxy": "runtime/agentguard-proxy",
      "bundle-resources/python/agentguard_sdk": "python/agentguard_sdk",
      "bundle-resources/python/live_demo_agent.py": "python/live_demo_agent.py",
      "bundle-resources/python/openai_chat_agent.py": "python/openai_chat_agent.py"
    }
  }
}
